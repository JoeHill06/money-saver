# Copy this file to .env and fill in your own credentials.
# Create a TrueLayer app at https://console.truelayer.com to get these.

TRUELAYER_CLIENT_ID=your-client-id-here
TRUELAYER_CLIENT_SECRET=your-client-secret-here

# The redirect URI must match exactly what you set in the TrueLayer console.
TRUELAYER_REDIRECT_URI=http://localhost:3000/callback

# Set to "true" to use the TrueLayer sandbox (test data), "false" for live bank.
USE_SANDBOX=false
